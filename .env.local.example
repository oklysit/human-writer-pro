# Server-side — enables the OAuth proxy route at /api/v1/messages
# Required for local-first testing with Claude Max subscription auth
# USE_LOCAL_OAUTH=1

# Client-side — tells the Anthropic SDK client to route through /api/v1/messages
# instead of directly to api.anthropic.com
# Must be set alongside USE_LOCAL_OAUTH when running `npm run dev` for OAuth testing
# NEXT_PUBLIC_USE_LOCAL_OAUTH=1
